LINE_CHANNEL_ACCESS_TOKEN=put-your-channel-access-token-here
LINE_CHANNEL_SECRET=put-your-channel-secret-here
PORT=3000

# true = unknown text also gets defaultReply from data/replies.json
REPLY_TO_UNKNOWN=false

# Protects /admin/metrics and /admin/broadcast.
# Use a long random value in production.
ADMIN_TOKEN=change-this-long-random-token

# info, warn, error, or debug
LOG_LEVEL=info

# false avoids storing user message text in logs.
LOG_MESSAGE_TEXT=false

# Used by npm run broadcast and GitHub Actions scheduled broadcast
LINE_BROADCAST_TEXT=本週提醒：記得查看最新活動與表單。
