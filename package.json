{
  "name": "line-auto-helper",
  "version": "1.0.0",
  "description": "Small LINE Messaging API service for keyword replies, health checks, and scheduled broadcasts.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "broadcast": "node scripts/broadcast.js",
    "validate:env": "node scripts/validate-env.js",
    "validate:rules": "node scripts/validate-rules.js",
    "validate": "npm run validate:rules && npm run lint && npm test",
    "lint": "node scripts/check-syntax.js",
    "smoke": "node scripts/smoke-test.js",
    "test": "node scripts/run-tests.js"
  },
  "keywords": [
    "line",
    "line-bot",
    "messaging-api",
    "automation",
    "github-actions"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@line/bot-sdk": "^11.0.2",
    "dotenv": "^16.6.1",
    "express": "^5.2.1"
  }
}
